{
  "$schema": "../../node_modules/turbo/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "!README.md"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "env": [
        "DEBUG",
        "DISCORD_BOT_TOKEN",
        "DISCORD_CLIENT_ID",
        "GITHUB_TOKEN",
        "JWKS_URL",
        "POSTHOG_API_KEY",
        "SENTRY_DSN",
        "TELEGRAM_BOT_TOKEN",
        "UPSTASH_REDIS_REST_TOKEN",
        "UPSTASH_REDIS_REST_URL"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".dev.vars", ".env", ".env.*"],
      "persistent": true
    },
    "deploy": {
      "dependsOn": ["^build"],
      "cache": false,
      "env": [
        "DEBUG",
        "DISCORD_BOT_TOKEN",
        "DISCORD_CLIENT_ID",
        "GITHUB_TOKEN",
        "JWKS_URL",
        "POSTHOG_API_KEY",
        "SENTRY_DSN",
        "TELEGRAM_BOT_TOKEN",
        "UPSTASH_REDIS_REST_TOKEN",
        "UPSTASH_REDIS_REST_URL"
      ]
    },
    "bot:set-commands": {
      "cache": false,
      "env": ["TELEGRAM_BOT_TOKEN"]
    }
  }
}
