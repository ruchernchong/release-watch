{
  "$schema": "../../node_modules/turbo/schema.json",
  "extends": ["//"],
  "tasks": {
    "dev": {
      "cache": false,
      "env": [
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "DATABASE_URL",
        "DISCORD_CLIENT_ID",
        "DISCORD_CLIENT_SECRET",
        "GITHUB_CLIENT_ID",
        "GITHUB_CLIENT_SECRET",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "NEXT_PUBLIC_API_URL",
        "NEXT_PUBLIC_DISCORD_CLIENT_ID",
        "NEXT_PUBLIC_POSTHOG_KEY",
        "POLAR_ACCESS_TOKEN",
        "POLAR_PRODUCT_ID_PRO_ANNUAL",
        "POLAR_PRODUCT_ID_PRO_MONTHLY",
        "POLAR_SERVER",
        "POLAR_WEBHOOK_SECRET"
      ],
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "CI",
        "DATABASE_URL",
        "DISCORD_CLIENT_ID",
        "DISCORD_CLIENT_SECRET",
        "GITHUB_CLIENT_ID",
        "GITHUB_CLIENT_SECRET",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "NEXT_PUBLIC_API_URL",
        "NEXT_PUBLIC_DISCORD_CLIENT_ID",
        "NEXT_PUBLIC_POSTHOG_KEY",
        "POLAR_ACCESS_TOKEN",
        "POLAR_PRODUCT_ID_PRO_ANNUAL",
        "POLAR_PRODUCT_ID_PRO_MONTHLY",
        "POLAR_SERVER",
        "POLAR_WEBHOOK_SECRET"
      ],
      "inputs": ["$TURBO_DEFAULT$", "!README.md", ".env", ".env.*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "start": {
      "dependsOn": ["build"],
      "env": [
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "DATABASE_URL",
        "DISCORD_CLIENT_ID",
        "DISCORD_CLIENT_SECRET",
        "GITHUB_CLIENT_ID",
        "GITHUB_CLIENT_SECRET",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "NEXT_PUBLIC_API_URL",
        "NEXT_PUBLIC_DISCORD_CLIENT_ID",
        "NEXT_PUBLIC_POSTHOG_KEY",
        "POLAR_ACCESS_TOKEN",
        "POLAR_PRODUCT_ID_PRO_ANNUAL",
        "POLAR_PRODUCT_ID_PRO_MONTHLY",
        "POLAR_SERVER",
        "POLAR_WEBHOOK_SECRET"
      ],
      "persistent": true
    }
  }
}
